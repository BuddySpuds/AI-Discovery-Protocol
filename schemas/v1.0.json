{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pressonify.ai/schemas/ai-discovery/v1.0.json",
  "title": "AI Discovery Protocol",
  "description": "Schema for AI Discovery Protocol v1.0.0 - enables AI systems to discover and understand website content",
  "type": "object",
  "required": ["$schema", "version", "generatedAt", "website", "endpoints", "metadata"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema reference for validation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the AI Discovery Protocol (e.g., 1.0.0)"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this file was generated (UTC with Z suffix)"
    },
    "website": {
      "type": "object",
      "required": ["url", "name"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Primary URL of the website"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name of the website or organization"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the website (1-2 sentences)"
        }
      }
    },
    "endpoints": {
      "type": "object",
      "required": ["knowledgeGraph"],
      "properties": {
        "knowledgeGraph": {
          "type": "object",
          "required": ["url", "format"],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "URL to the knowledge graph JSON-LD file"
            },
            "format": {
              "type": "string",
              "enum": ["application/ld+json"],
              "description": "MIME type of the knowledge graph"
            },
            "entityCount": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of entities in the knowledge graph"
            },
            "lastModified": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp of last update"
            }
          }
        },
        "contextDocument": {
          "type": "object",
          "required": ["url", "format"],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "URL to the LLM context document (llms.txt)"
            },
            "format": {
              "type": "string",
              "enum": ["text/markdown", "text/plain"],
              "description": "MIME type of the context document"
            },
            "lastModified": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp of last update"
            }
          }
        },
        "crawlerDirectives": {
          "type": "object",
          "required": ["url", "allowsAI"],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "URL to robots.txt"
            },
            "allowsAI": {
              "type": "boolean",
              "description": "Whether AI crawlers are allowed"
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["language", "updateFrequency"],
      "properties": {
        "industry": {
          "type": "string",
          "description": "Primary industry classification"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "Primary language (ISO 639-1 code, e.g., 'en', 'en-US')"
        },
        "updateFrequency": {
          "type": "string",
          "enum": ["realtime", "hourly", "daily", "weekly", "monthly", "quarterly", "annually"],
          "description": "How often content is updated"
        },
        "timezone": {
          "type": "string",
          "description": "IANA timezone identifier (e.g., 'America/New_York', 'UTC')"
        }
      }
    },
    "shopify": {
      "type": "object",
      "description": "Shopify-specific extensions (not part of core spec)",
      "properties": {
        "entityCounts": {
          "type": "object",
          "properties": {
            "products": {"type": "integer", "minimum": 0},
            "collections": {"type": "integer", "minimum": 0},
            "blogs": {"type": "integer", "minimum": 0},
            "pages": {"type": "integer", "minimum": 0}
          }
        },
        "optimizationStatus": {
          "type": "object",
          "properties": {
            "totalOptimized": {"type": "integer", "minimum": 0},
            "averageScore": {"type": "number", "minimum": 0, "maximum": 100}
          }
        },
        "features": {
          "type": "object",
          "properties": {
            "searchNotification": {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean"},
                "provider": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
